# ─────────────────────────────────────────────────────────────────
# JARM TLS FINGERPRINTER (raw socket implementation)
#
# JARM sends 10 specially crafted TLS Client Hellos and records
# the server's cipher selection. The resulting fingerprint
# identifies server software across shared/CDN infrastructure.
# ─────────────────────────────────────────────────────────────────

# Standard cipher suites for probes
_ALL12 = [
    0xc02b, 0xc02c, 0xc02f, 0xc030, 0x009e, 0x009f,
    0xc013, 0xc014, 0xc00a, 0xc009, 0x009c, 0x009d,
    0x002f, 0x0035, 0xc012, 0xc011, 0x000a,
]
_13ONLY = [0x1301, 0x1302, 0x1303, 0x1304, 0x1305]
_GREASE  = 0x1a1a   # single GREASE token

# Probe spec: (tls_record_ver, ch_ver, ciphers, use_grease, alpn, reverse_ciphers, add_1_3_ext)
_PROBES = [
    (0x0301, 0x0303, _ALL12,        True,  None,     False, False),
    (0x0301, 0x0303, _ALL12,        True,  None,     True,  False),
    (0x0301, 0x0303, _ALL12,        False, None,     False, False),
    (0x0301, 0x0303, _ALL12,        True,  "h2",     False, False),
    (0x0301, 0x0303, _ALL12,        True,  "http/1.1",False, False),
    (0x0301, 0x0304, _13ONLY+_ALL12,True,  None,     False, True),
    (0x0301, 0x0304, _13ONLY+_ALL12,True,  None,     True,  True),
    (0x0301, 0x0304, _13ONLY,       False, None,     False, True),
    (0x0301, 0x0304, _13ONLY+_ALL12,True,  "h2",     False, True),
    (0x0301, 0x0304, _13ONLY+_ALL12,False, None,     False, True),
]


def _sni_ext(host: str) -> bytes:
    h = host.encode()
    entry   = struct.pack("!BH", 0, len(h)) + h          # type + len + name
    list_   = struct.pack("!H", len(entry)) + entry       # list length
    return struct.pack("!HH", 0x0000, len(list_)) + list_ # type + ext len


def _supported_versions_ext(max_ver: int) -> bytes:
    """0x002b — SupoprtedVersions"""
    versions = [0x0304, 0x0303, 0x0302, 0x0301] if max_ver >= 0x0304 else [0x0303, 0x0302, 0x0301]
    payload  = struct.pack("!B", len(versions) * 2) + b"".join(struct.pack("!H", v) for v in versions)
    return struct.pack("!HH", 0x002b, len(payload)) + payload


def _supported_groups_ext() -> bytes:
    groups  = [0x001d, 0x0017, 0x0018, 0x0019]  # x25519, P-256, P-384, P-521
    payload = struct.pack("!H", len(groups) * 2) + b"".join(struct.pack("!H", g) for g in groups)
    return struct.pack("!HH", 0x000a, len(payload) + 2) + struct.pack("!H", len(payload)) + payload


def _alpn_ext(proto: str) -> bytes:
    p       = proto.encode()
    entry   = struct.pack("!B", len(p)) + p
    list_   = struct.pack("!H", len(entry)) + entry
    return struct.pack("!HH", 0x0010, len(list_)) + list_


def _key_share_ext() -> bytes:
    key   = os.urandom(32)
    entry = struct.pack("!HH", 0x001d, len(key)) + key   # x25519
    list_ = struct.pack("!H", len(entry)) + entry
    return struct.pack("!HH", 0x0033, len(list_)) + list_


def _build_client_hello(
    host:            str,
    record_ver:      int,
    ch_ver:          int,
    ciphers:         list[int],
    use_grease:      bool,
    alpn:            Optional[str],
    reverse_ciphers: bool,
    add_1_3_ext:     bool,
) -> bytes:
    import os as _os
    rnd      = _os.urandom(32)
    sess_id  = _os.urandom(32)

    cs_list  = list(reversed(ciphers)) if reverse_ciphers else list(ciphers)
    if use_grease:
        cs_list = [_GREASE] + cs_list
    cs_bytes  = b"".join(struct.pack("!H", c) for c in cs_list)
    cs_block  = struct.pack("!H", len(cs_bytes)) + cs_bytes
    comp      = b"\x01\x00"  # 1 method, null

    # Extensions
    exts = b""
    exts += _sni_ext(host)
    if add_1_3_ext:
        exts += _supported_versions_ext(ch_ver)
    exts += _supported_groups_ext()
    exts += b"\x00\x0b\x00\x02\x01\x00"           # ec_point_formats
    exts += b"\x00\x23\x00\x00"                    # session_ticket
    exts += b"\x00\x16\x00\x00"                    # encrypt_then_mac
    exts += b"\x00\x17\x00\x00"                    # extended_master_secret
    sig  = bytes.fromhex(
        "04030503060308040805080604010501060105010401"
        "0302030102020201"
    )
    exts += struct.pack("!HHH", 0x000d, len(sig) + 2, len(sig)) + sig
    if alpn:
        exts += _alpn_ext(alpn)
    if add_1_3_ext:
        exts += _key_share_ext()
        exts += b"\x00\x2d\x00\x02\x01\x01"        # psk_key_exchange_modes

    ext_block = struct.pack("!H", len(exts)) + exts

    ch_body = (
        struct.pack("!H", ch_ver) + rnd
        + struct.pack("!B", len(sess_id)) + sess_id
        + cs_block + comp + ext_block
    )
    hs     = b"\x01" + struct.pack("!I", len(ch_body))[1:] + ch_body
    record = struct.pack("!BHH", 0x16, record_ver, len(hs)) + hs
    return record


def _send_probe(host: str, port: int, pkt: bytes, timeout: float = 3.0) -> bytes:
    try:
        with socket.create_connection((host, port), timeout=timeout) as s:
            s.sendall(pkt)
            data = b""
            s.settimeout(timeout)
            try:
                while True:
                    chunk = s.recv(4096)
                    if not chunk:
                        break
                    data += chunk
                    # Stop once we have the Server Hello record (type 0x16)
                    if len(data) > 9 and data[0] == 0x16:
                        break
            except socket.timeout:
                pass
            return data
    except Exception:
        return b""


def _parse_server_hello(data: bytes) -> tuple[str, str]:
    """
    Returns (cipher_hex, tls_version_hex) from Server Hello,
    or ("", "") on failure.
    """
    if len(data) < 5 or data[0] != 0x16:
        return "", ""
    try:
        rec_len    = struct.unpack("!H", data[3:5])[0]
        hs         = data[5: 5 + rec_len]
        if not hs or hs[0] != 0x02:          # ServerHello
            return "", ""
        hs_len     = struct.unpack("!I", b"\x00" + hs[1:4])[0]
        body       = hs[4: 4 + hs_len]
        version    = struct.unpack("!H", body[0:2])[0]
        # Skip random(32) + session_id_length(1) + session_id
        offset     = 34
        sid_len    = body[offset]
        offset    += 1 + sid_len
        cipher     = struct.unpack("!H", body[offset: offset + 2])[0]
        return f"{cipher:04x}", f"{version:04x}"
    except Exception:
        return "", ""


def jarm_fingerprint(host: str, port: int = 443) -> str:
    """
    Compute a JARM fingerprint for host:port.
    Returns 62-character hex string, or '' on failure.
    """
    raw_parts: list[str] = []
    for (rec_ver, ch_ver, ciphers, grease, alpn, rev, ext13) in _PROBES:
        pkt    = _build_client_hello(host, rec_ver, ch_ver, ciphers, grease, alpn, rev, ext13)
        resp   = _send_probe(host, port, pkt)
        cipher, ver = _parse_server_hello(resp)
        raw_parts.append(f"{cipher}|{ver}")
        time.sleep(0.1)  # polite spacing between probes

    raw = ",".join(raw_parts)
    # Fuzzy hash: sha256 of raw, take first 62 hex chars
    digest = hashlib.sha256(raw.encode()).hexdigest()[:62]
    logger.info(f"[JARM] {host}:{port} → {digest}")
    return digest


# ─────────────────────────────────────────────────────────────────
# DNS RESOLVER — CIRCL pDNS + Google DoH fallback
# ─────────────────────────────────────────────────────────────────

class DNSResolver:
    CIRCL_BASE = "https://www.circl.lu/pdns/query"
    DOH_BASE   = "https://dns.google/resolve"

    def __init__(
        self,
        circl_user:     Optional[str] = None,
        circl_password: Optional[str] = None,
    ):
        self.auth    = (circl_user, circl_password) if circl_user else None
        self.session = requests.Session()
        self.session.headers["Accept"] = "application/json"

    def resolve_circl(self, domain: str) -> list[dict]:
        """
        CIRCL pDNS returns historical DNS records (A, AAAA, MX, NS, CNAME).
        Requires auth for production rate limits; unauthenticated allowed.
        Docs: https://www.circl.lu/services/passive-dns/
        """
        records: list[dict] = []
        try:
            r = self.session.get(
                f"{self.CIRCL_BASE}/{domain}",
                auth=self.auth,
                timeout=15,
            )
            if r.status_code == 401:
                logger.warning("[pDNS] Auth required — falling back to DoH")
                return []
            r.raise_for_status()
            # Response is NDJSON
            for line in r.text.strip().splitlines():
                try:
                    records.append(json.loads(line))
                except json.JSONDecodeError:
                    continue
            logger.info(f"[pDNS] {domain} → {len(records)} historical records")
        except requests.RequestException as e:
            logger.debug(f"[pDNS] {domain}: {e}")
        return records

    def resolve_doh(self, domain: str, qtype: str = "A") -> list[str]:
        """Google DNS-over-HTTPS — returns current A/AAAA records."""
        ips: list[str] = []
        try:
            r = self.session.get(
                self.DOH_BASE,
                params={"name": domain, "type": qtype},
                timeout=10,
            )
            r.raise_for_status()
            for ans in r.json().get("Answer", []):
                val = ans.get("data", "").strip()
                if qtype == "A" and self._is_ipv4(val):
                    ips.append(val)
                elif qtype == "AAAA" and ":" in val:
                    ips.append(val)
        except requests.RequestException as e:
            logger.debug(f"[DoH] {domain}: {e}")
        return ips

    def resolve(self, domain: str) -> list[dict]:
        """
        Full resolution pipeline.
        Returns unified list of {rrname, rrtype, rdata, first_seen, last_seen}.
        """
        pdns = self.resolve_circl(domain)
        if pdns:
            return pdns

        # Fallback — current DNS only
        current: list[dict] = []
        now = datetime.utcnow().isoformat()
        for qtype in ("A", "AAAA"):
            for ip in self.resolve_doh(domain, qtype):
                current.append({
                    "rrname": domain,
                    "rrtype": qtype,
                    "rdata": ip,
                    "first_seen": now,
                    "last_seen": now,
                    "source": "google_doh",
                })
        logger.info(f"[DoH] {domain} → {len(current)} current records")
        return current

    @staticmethod
    def _is_ipv4(val: str) -> bool:
        try:
            ipaddress.IPv4Address(val)
            return True
        except ValueError:
            return False


