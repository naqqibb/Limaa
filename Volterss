class RIPEStatEnricher:
    BASE = "https://stat.ripe.net/data"

    def __init__(self):
        self.session = requests.Session()
        self.session.headers["User-Agent"] = "RHIZOME-NEXUS/1.0 research"
        self._cache: dict[str, dict] = {}

    def ip_to_network_info(self, ip: str) -> dict:
        """Returns {asns, prefix} for an IP."""
        if ip in self._cache:
            return self._cache[ip]
        try:
            r = self.session.get(
                f"{self.BASE}/network-info/data.json",
                params={"resource": ip}, timeout=10,
            )
            r.raise_for_status()
            data = r.json().get("data", {})
            result = {
                "asns":   data.get("asns", []),
                "prefix": data.get("prefix"),
            }
            self._cache[ip] = result
            time.sleep(0.2)  # RIPE Stat rate limit courtesy
            return result
        except Exception as e:
            logger.debug(f"[RIPE] network-info {ip}: {e}")
            return {}

    def asn_overview(self, asn: str) -> dict:
        """Returns {holder, announced, type} for ASN."""
        asn = asn.lstrip("AS").lstrip("as")
        try:
            r = self.session.get(
                f"{self.BASE}/as-overview/data.json",
                params={"resource": f"AS{asn}"}, timeout=10,
            )
            r.raise_for_status()
            data = r.json().get("data", {})
            time.sleep(0.2)
            return {
                "asn":      f"AS{asn}",
                "holder":   data.get("holder", ""),
                "announced":data.get("announced", False),
                "type":     data.get("type", ""),
            }
        except Exception as e:
            logger.debug(f"[RIPE] as-overview AS{asn}: {e}")
            return {}

    def geo_ip(self, ip: str) -> dict:
        """Geolocation via RIPE Stat ris-peers (best-effort)."""
        try:
            r = self.session.get(
                f"{self.BASE}/ris-peers/data.json",
                params={"resource": ip}, timeout=10,
            )
            r.raise_for_status()
            peers = r.json().get("data", {}).get("peers", [])
            if peers:
                p = peers[0]
                time.sleep(0.2)
                return {
                    "country": p.get("peer_country", ""),
                    "city":    "",
                }
        except Exception:
            pass
        return {}

    def enrich(self, ip: str) -> dict:
        """Full enrichment for a single IP."""
        net  = self.ip_to_network_info(ip)
        asns = net.get("asns", [])
        asn_detail: dict = {}
        if asns:
            asn_detail = self.asn_overview(asns[0])
        geo = self.geo_ip(ip)
        return {
            "ip":      ip,
            "asns":    asns,
            "prefix":  net.get("prefix"),
            "holder":  asn_detail.get("holder", ""),
            "asn_str": asn_detail.get("asn", ""),
            "country": geo.get("country", ""),
        }


